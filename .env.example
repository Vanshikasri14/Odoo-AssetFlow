# ─── Database ────────────────────────────────────────────────────────────────
# Neon Postgres → console.neon.tech → your project → Connect.
# You need BOTH strings. They differ only by "-pooler" in the hostname.
#
# Pooled — used by the app at runtime. Serverless opens a connection per
# request, so it must go through PgBouncer.
#
# ⚠ The query flags are NOT optional:
#   pgbouncer=true      Neon's pooler runs PgBouncer in transaction mode, which
#                       cannot hold prepared statements across statements. Without
#                       this, Prisma's prepared statements make the pooler forcibly
#                       close the connection (ECONNRESET) and pages fail on load.
#   connection_limit=5  Our pages fire 5–7 queries in one Promise.all. With a
#                       limit of 1 they queue behind a single connection and time
#                       out. (Prisma's connection_limit=1 advice is for a
#                       serverless function serving ONE request, not a server.)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=5&pool_timeout=20&connect_timeout=15"

# Direct — used by `prisma db push` and migrations, which take Postgres
# advisory locks that the pooler will not pass through. Toggle "Connection
# pooling" OFF in the Neon dialog to get this one.
DIRECT_URL="postgresql://user:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Signing key for the session JWT. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change-me-to-a-32-byte-random-hex-string"

# ─── Seed ────────────────────────────────────────────────────────────────────
# Password given to every seeded demo account (admin@assetflow.io, etc.)
SEED_PASSWORD="assetflow123"
