# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit real credentials.
# .env.example is the template and carries no secrets, so it is opted back in.
.env*
!.env.example

# internal team docs — task splits, the brief PDF, agent notes.
# Not for the public repo.
/docs/
CLAUDE.md
AGENTS.md

# Local dev utility: forges a session cookie so the app's HTTP endpoints can be
# driven from a terminal to test RBAC. Needs SESSION_SECRET, so it grants nothing
# you don't already have — but it is a test artifact, not product code.
/scripts/mint-session.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
